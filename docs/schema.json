      "additionalProperties": false,
      "properties": {
        "managed_principals": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "managed_resources": {
          "items": {
            "$ref": "#/$defs/resourcePattern"
          },
          "type": "array"
        },
        "unmanaged_action": {
          "enum": [
            "warn",
            "warning",
            "error",
            "ignore"
          ]
        }
      },
      "type": "object"
    },
    "resource": {
      "oneOf": [
        {
          "$ref": "#/$defs/catalogResource"
        },
        {
          "$ref": "#/$defs/databaseResource"
        },
        {
          "$ref": "#/$defs/tableResource"
        },
        {
          "$ref": "#/$defs/tableWithColumnsResource"
        },
        {
          "$ref": "#/$defs/dataLocationResource"
        },
        {
          "$ref": "#/$defs/lfTagPolicyResource"
        },
        {
          "$ref": "#/$defs/lfTagExpressionResource"
        }
      ]
    },
    "resourcePattern": {
      "oneOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "database": {
              "minLength": 1,
              "type": "string"
            },
            "expression_name": {
              "minLength": 1,
              "type": "string"
            },
            "kind": {
              "enum": [
                "catalog",
                "database",
                "table",
                "table_with_columns",
                "data_location",
                "lf_tag_policy",
                "lf_tag_expression"
              ]
            },
            "location": {
              "minLength": 1,
              "type": "string"
            },
            "table": {
              "minLength": 1,
              "type": "string"
            }
          },
          "type": "object"
        }
      ]
    },
    "resourceTagAssignment": {
      "additionalProperties": false,
      "properties": {
        "resource": {
          "$ref": "#/$defs/resource"
        },
        "tags": {
          "additionalProperties": {
            "oneOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array",
                "uniqueItems": true
              }
            ]
          },
          "type": "object"
        }
      },
      "required": [
        "resource",
        "tags"
      ],
      "type": "object"
    },
    "tableResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "database": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "table"
        },
        "table": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "kind",
        "database",
        "table"
      ],
      "type": "object"
    },
    "tableWithColumnsResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "columns": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "database": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "table_with_columns"
        },
        "table": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "kind",
        "database",
        "table",
        "columns"
      ],
      "type": "object"
    },
    "tagAssignmentScopeList": {
      "oneOf": [
        {
          "enum": [
            "database",
            "table",
            "column"
          ]
        },
        {
          "items": {
            "enum": [
              "database",
              "table",
              "column"
            ]
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        }
      ]
    }
  },
  "$id": "https://raw.githubusercontent.com/yongjip/aws-datalake-guard/main/docs/schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Desired or current AWS Lake Formation LF-Tag guardrail state.",
  "properties": {
    "grants": {
      "items": {
        "$ref": "#/$defs/grant"
      },
      "type": "array"
    },
    "ignore": {
      "$ref": "#/$defs/ignoreConfig"
    },
    "lf_tag_expressions": {
      "description": "Named LF-Tag expressions.",
      "oneOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/lfTagExpressionValue"
          },
          "type": "object"
        },
        {
          "items": {
            "$ref": "#/$defs/lfTagExpression"
          },
          "type": "array"
        }
      ]
    },
    "lf_tag_key_metadata": {
      "description": "Optional authoring metadata for LF-Tag assignment scope.",
      "oneOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/lfTagKeyMetadataValue"
          },
          "type": "object"
        },
        {
          "items": {
            "$ref": "#/$defs/lfTagKeyMetadata"
          },
          "type": "array"
        }
      ]
    },
    "lf_tags": {
      "description": "LF-Tag keys and allowed values.",
      "oneOf": [
        {
          "additionalProperties": {
            "oneOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array",
                "uniqueItems": true
              }
            ]
          },
          "type": "object"
        },
        {
          "items": {
            "$ref": "#/$defs/lfTagDefinition"
          },
          "type": "array"
        }
      ]
    },
    "lint": {
      "additionalProperties": {
        "enum": [
          "error",
          "warning",
          "ignore"
        ]
      },
      "type": "object"
    },
    "ownership": {
      "$ref": "#/$defs/ownershipConfig"
    },
    "resource_tags": {
      "items": {
        "$ref": "#/$defs/resourceTagAssignment"
      },
      "type": "array"
    }
  },
  "title": "lfguard state",
  "type": "object"
}
