    "grant": {
      "additionalProperties": false,
      "properties": {
        "grantable_permissions": {
          "oneOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            }
          ]
        },
        "permissions": {
          "oneOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            }
          ]
        },
        "principal": {
          "minLength": 1,
          "type": "string"
