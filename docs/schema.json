        "assignable_to"
      ],
      "type": "object"
    },
    "lfTagPolicyResource": {
      "additionalProperties": false,
      "properties": {
        "expression": {
          "oneOf": [
            {
              "additionalProperties": {
                "oneOf": [
                  {
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "items": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "minItems": 1,
                    "type": "array",
                    "uniqueItems": true
                  }
                ]
              },
              "type": "object"
            },
            {
              "items": {
                "$ref": "#/$defs/lfTagDefinition"
              },
              "minItems": 1,
              "type": "array"
            }
          ]
        },
        "kind": {
          "const": "lf_tag_policy"
        },
        "resource_type": {
          "enum": [
            "DATABASE",
            "TABLE"
          ]
