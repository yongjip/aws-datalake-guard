{
  "$defs": {
    "catalogResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "catalog"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "dataLocationResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "data_location"
        },
        "location": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "kind",
        "location"
      ],
      "type": "object"
    },
    "databaseResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "database": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "database"
        }
      },
      "required": [
        "kind",
        "database"
      ],
      "type": "object"
    },
    "grant": {
      "additionalProperties": false,
      "properties": {
        "grantable_permissions": {
          "oneOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            }
          ]
        },
        "permissions": {
          "oneOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            }
          ]
        },
        "principal": {
          "minLength": 1,
          "type": "string"
        },
        "resource": {
          "$ref": "#/$defs/resource"
        }
      },
      "required": [
        "principal",
        "resource",
        "permissions"
      ],
      "type": "object"
