              "type": "string"
            },
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            }
          ]
        }
      },
      "required": [
        "key",
        "values"
      ],
      "type": "object"
    },
    "lfTagKeyMetadata": {
      "additionalProperties": false,
