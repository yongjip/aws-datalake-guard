    "ignoreConfig": {
      "additionalProperties": false,
      "properties": {
        "principals": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "resources": {
          "items": {
            "$ref": "#/$defs/resourcePattern"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "lfTagDefinition": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "minLength": 1,
          "type": "string"
        },
        "values": {
          "oneOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "minItems": 1,
              "type": "array",
              "uniqueItems": true
            }
          ]
        }
      },
      "required": [
        "key",
        "values"
      ],
      "type": "object"
    },
    "lfTagExpression": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "expression": {
          "$ref": "#/$defs/lfTagExpressionBody"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "expression"
      ],
      "type": "object"
    },
    "lfTagExpressionBody": {
      "oneOf": [
        {
          "additionalProperties": {
            "oneOf": [
              {
                "minLength": 1,
                "type": "string"
              },
              {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array",
                "uniqueItems": true
              }
            ]
          },
          "type": "object"
        },
        {
          "items": {
            "$ref": "#/$defs/lfTagDefinition"
          },
          "minItems": 1,
          "type": "array"
        }
      ]
    },
    "lfTagExpressionResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "expression_name": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "lf_tag_expression"
        }
      },
      "required": [
        "kind",
        "expression_name"
      ],
      "type": "object"
    },
    "lfTagExpressionValue": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "expression": {
          "$ref": "#/$defs/lfTagExpressionBody"
        }
      },
      "required": [
        "expression"
      ],
      "type": "object"
    },
    "lfTagKeyMetadata": {
      "additionalProperties": false,
      "properties": {
        "assignable_to": {
          "$ref": "#/$defs/tagAssignmentScopeList"
        },
        "key": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "key",
        "assignable_to"
      ],
      "type": "object"
    },
    "lfTagKeyMetadataValue": {
      "additionalProperties": false,
      "properties": {
        "assignable_to": {
          "$ref": "#/$defs/tagAssignmentScopeList"
        }
      },
      "required": [
        "assignable_to"
      ],
      "type": "object"
    },
    "lfTagPolicyResource": {
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "expression"
          ]
        },
        {
          "required": [
            "expression_name"
          ]
        }
      ],
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "expression": {
          "$ref": "#/$defs/lfTagExpressionBody"
        },
        "expression_name": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "lf_tag_policy"
        },
        "resource_type": {
          "enum": [
            "DATABASE",
            "TABLE"
          ]
        }
      },
      "required": [
        "kind",
        "resource_type"
      ],
      "type": "object"
    },
