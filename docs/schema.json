        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "dataLocationResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "const": "data_location"
        },
        "location": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "kind",
        "location"
      ],
      "type": "object"
    },
    "databaseResource": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "database": {
          "minLength": 1,
